# Environment variables for the Java backend (Spring Boot reads from env or application.yml).
# Copy to .env and fill in real values. Do NOT commit .env.

AZURE_SQL_SERVER=ai-rag-sql-server.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=ai-rag-db-1
AZURE_SQL_USER=your_sql_login
AZURE_SQL_PASSWORD=your_password

# Must match frontend VITE_OPS_TOKEN; leave blank to skip auth (local dev).
OPS_TOKEN=

# Allowed browser origins, comma-separated (matches application.yml CORS_ORIGINS).
CORS_ORIGINS=http://localhost:5173

# Azure OpenAI embeddings (ingest). Use Key Vault reference on App Service for the key.
AZURE_OPENAI_ENDPOINT=https://ai-reg-embedding.openai.azure.com
AZURE_OPENAI_API_KEY=
# Deployment name from Azure AI Studio / OpenAI resource (e.g. text-embedding-3-small)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01
# true = skip vectors (local dev only)
AZURE_OPENAI_SKIP_EMBEDDING=false

# Azure AI Search (hybrid RAG index). Create index from db/azure_search_index_risk_records.json first.
AZURE_SEARCH_ENDPOINT=https://airagsearchsxgu.search.windows.net
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=risk-records
AZURE_SEARCH_API_VERSION=2024-07-01
# true = skip push to AI Search (local dev)
AZURE_SEARCH_SKIP=false
