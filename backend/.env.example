# Azure OpenAI — one resource, two deployments (same endpoint + key).
# Copy this file to .env (same folder as pom.xml or repo root) and fill values. .env is gitignored.
# Local runs: Spring loads .env automatically (see DotEnvEnvironmentPostProcessor); App Service uses Application Settings.

AZURE_SQL_SERVER=ai-rag-sql-server.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=ai-rag-db-1
AZURE_SQL_USER=your_sql_login
AZURE_SQL_PASSWORD=your_password

# Must match frontend VITE_OPS_TOKEN; leave blank to skip auth (local dev).
OPS_TOKEN=

# Allowed browser origins, comma-separated (matches application.yml CORS_ORIGINS).
CORS_ORIGINS=http://localhost:5173

# Azure OpenAI embeddings (ingest) + chat (assess label). Same endpoint/key.
# Resource: ai-reg-embedding — create deployments under Foundry → Shared resources → Deployments.
AZURE_OPENAI_ENDPOINT=https://ai-reg-embedding.openai.azure.com
AZURE_OPENAI_API_KEY=
# Deployment names exactly as shown in Foundry (Models + endpoints → Deployments):
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# Optional; default 2024-08-01-preview in app when blank (json_object response_format).
AZURE_OPENAI_CHAT_API_VERSION=
AZURE_OPENAI_API_VERSION=2024-02-01
# true = skip vectors (local dev only)
AZURE_OPENAI_SKIP_EMBEDDING=false
# true = skip assess chat step (retrieval only)
AZURE_OPENAI_SKIP_CHAT=false

# Azure AI Search (hybrid RAG index). Create index from db/azure_search_index_risk_records.json first.
AZURE_SEARCH_ENDPOINT=https://airagsearchsxgu.search.windows.net
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=risk-records
AZURE_SEARCH_API_VERSION=2024-07-01
# true = skip push to AI Search (local dev)
AZURE_SEARCH_SKIP=false
