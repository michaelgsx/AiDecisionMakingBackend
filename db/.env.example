# Azure SQL connection (paste from Key Vault secret db-1-connection or fill discrete fields).
# Option A: full connection string
# AZURE_SQL_CONNECTION_STRING=Server=tcp:ai-rag-sql-server.database.windows.net,1433;Initial Catalog=ai-rag-db-1;User ID=...;Password=...;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Option B: discrete fields
AZURE_SQL_SERVER=ai-rag-sql-server.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=ai-rag-db-1
AZURE_SQL_USER=your_sql_login
AZURE_SQL_PASSWORD=your_password

# --- Required for db/backfill_azure_search.py, embed_text_features.py (same as App Service) ---
AZURE_OPENAI_ENDPOINT=https://ai-reg-embedding.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01

AZURE_SEARCH_ENDPOINT=https://airagsearchsxgu.search.windows.net
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=risk-records
AZURE_SEARCH_API_VERSION=2024-07-01
