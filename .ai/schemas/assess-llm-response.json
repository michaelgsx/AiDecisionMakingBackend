{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aidecision.local/schemas/assess-llm-response.json",
  "title": "AssessChatCompletion",
  "description": "Azure OpenAI chat completion content for POST /rag/assess (response_format: json_object)",
  "type": "object",
  "additionalProperties": false,
  "required": ["label", "reasoning", "evidence"],
  "properties": {
    "label": {
      "type": "string",
      "enum": ["passed", "rejected", "frozen"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "key_risk_factors": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1 }
    },
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retrieval_and_scores",
        "feature_comparison",
        "narrative_alignment",
        "historical_decisions",
        "synthesis"
      ],
      "properties": {
        "retrieval_and_scores": { "type": "string", "minLength": 1 },
        "feature_comparison": { "type": "string", "minLength": 1 },
        "narrative_alignment": { "type": "string", "minLength": 1 },
        "historical_decisions": { "type": "string", "minLength": 1 },
        "synthesis": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "items"],
      "properties": {
        "summary": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceItem" }
        }
      }
    },
    "reason": {
      "type": "string",
      "description": "Legacy monolithic field; maps to reasoning.synthesis only"
    }
  },
  "$defs": {
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "claim", "supports_label"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["similar_case", "current_feature", "narrative"]
        },
        "record_id": { "type": "string" },
        "similarity_score": { "type": "number" },
        "review_outcome": {
          "type": "string",
          "enum": ["passed", "rejected", "frozen"]
        },
        "field": { "type": "string" },
        "value": { "type": "string" },
        "claim": { "type": "string", "minLength": 1 },
        "quote": { "type": "string" },
        "supports_label": {
          "type": "string",
          "enum": ["passed", "rejected", "frozen"]
        }
      }
    }
  }
}
